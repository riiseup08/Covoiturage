# Environment variables for Covoiturage.Africa
# Copy this file to .env and fill in your values

# ============ General ============
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False
DJANGO_ENV=development

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CSRF trusted origins (for HTTPS)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://your-domain.com

# CORS allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.com


# ============ Database ============
# For production, use PostgreSQL or MySQL
# DATABASE_URL=postgres://user:password@localhost:5432/covoiturage


# ============ Redis (Caching) ============
REDIS_URL=redis://localhost:6379/0


# ============ Email (SMTP) ============
# Example for Gmail:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@your-domain.com

# Example for SendGrid:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# DEFAULT_FROM_EMAIL=noreply@your-domain.com


# ============ JWT Settings ============
# Access token lifetime in minutes (default: 1440 = 24 hours)
# JWT_ACCESS_TOKEN_LIFETIME=1440

# Refresh token lifetime in minutes (default: 10080 = 7 days)
# JWT_REFRESH_TOKEN_LIFETIME=10080


# ============ Rate Limiting ============
# Requests per minute for anonymous users
# RATE_LIMIT_PER_MINUTE=60


# ============ Corridor Matching ============
# Match passengers whose pickup/dropoff lie ALONG a driver's route, not just exact
# city matches. Distances are vs the straight-line chord, so thresholds are generous
# to absorb road curvature; production should use road routing (OSRM) + tighter values.
# CORRIDOR_MATCHING_ENABLED=true
# MAX_PICKUP_DETOUR_KM=30
# MAX_DROPOFF_DETOUR_KM=30


# ============ Mobile-Money Escrow ============
# Provider for holding/releasing passenger fares. Default is an in-memory stub that
# requires no account. For real payments, point to the Monetbil adapter + set keys.
# PAYMENT_PROVIDER=covoiturage.payments.stub.StubProvider
# PAYMENT_PROVIDER=covoiturage.payments.monetbil.MonetbilProvider
# MONETBIL_SERVICE_KEY=
# MONETBIL_SERVICE_SECRET=


# ============ USSD / SMS (feature phones) ============
# Enable the /ussd/ webhook + SMS notifications for users without smartphones/data.
# Default SMS gateway logs to the console; switch to Africa's Talking for real SMS.
# USSD_ENABLED=false
# SMS_GATEWAY=covoiturage.messaging_gateway.console.ConsoleGateway
# SMS_GATEWAY=covoiturage.messaging_gateway.africastalking.AfricasTalkingGateway
# AT_USERNAME=
# AT_API_KEY=


# ============ Growth & Safety ============
# Public base URL used to build share / SOS / trip-status links sent over SMS.
# SITE_URL=https://covoitafrica.com

# Women-only rides (offered only by female drivers; never matched/shown to others).
# WOMEN_ONLY_ENABLED=true

# Referral bonus (FCFA/XAF) credited to BOTH users on the referee's first
# completed trip.
# REFERRAL_BONUS_XAF=500
